<Window x:Class="INFOTC4400_FinalProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:INFOTC4400_FinalProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="675" Width="600" Background="AntiqueWhite">
    <Grid>
        <Grid>
            <!--This is to split the "plan" side and "Grocery/notes" side of the -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <!--This is for the right side rows -->
            <Border Grid.Column="1" BorderBrush="RosyBrown" CornerRadius="0" BorderThickness="1">
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>

                    <!--Grocery List/Ingredient-->
                    <Button Grid.Row="0" Height="23" Width="60" Content="Clear All" BorderBrush="RosyBrown" Background="white" Click="ClearAllButton_Click" HorizontalAlignment="Left" Margin="10,10,178,17"/>

                    <ComboBox x:Name="FilterComboBox" SelectionChanged="Filter_ComboBox" Grid.Row="0" Width="60" Height="23" HorizontalAlignment="Right" Background="White" Margin="0,9,10,18">
                        <ComboBoxItem IsSelected="True" Content="Filter"/>
                        <ComboBoxItem Content="A-Z"/>
                        <ComboBoxItem Content="Z-A"/>
                        <ComboBoxItem Content="Category"/>
                    </ComboBox>
                    <Label Content="Grocery List" Grid.Row="0" FontWeight="Bold"  FontSize="15"  Margin="50,20,50,0" Width="100" VerticalAlignment="Top"/>
                    <ListBox BorderBrush="RosyBrown" BorderThickness="1.5" x:Name="GroceryListBox" SelectionChanged="GroceryList_SelectionChanged" Grid.Row="1" HorizontalAlignment="Left" Height="245" Margin="25,0,0,0" VerticalAlignment="Top" Width="200" />

                    <Label Content="Item" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Grid.RowSpan="2"/>
                    <TextBox BorderBrush="RosyBrown" x:Name="ItemName_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                    <Label Content="Quantity" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,30,0,0"/>
                    <TextBox BorderBrush="RosyBrown" x:Name="Quantity_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" Margin="0,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                    <Label Content="Category" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,60,0,0" Grid.RowSpan="2"/>
                    <TextBox BorderBrush="RosyBrown" x:Name="Category_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" Margin="0,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                    <Label Content="Measurement" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,85,0,0" Grid.RowSpan="2"/>
                    <TextBox BorderBrush="RosyBrown" Name="Measurement_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" Margin="0,90,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                    <Label Content="Has this item been purchased?" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,112,0,0" Grid.RowSpan="2"/>
                    <CheckBox Grid.Row="3" x:Name="IsBought_CheckBox" Checked="IsBought" Margin="220,120,0,150" HorizontalAlignment="Left" Width="48" />

                    <Button Grid.Row="3" Height="23" Width="50" Content="Save" x:Name="SaveButton" BorderBrush="RosyBrown" Background="white" Click="SaveButton_Click" Margin="195,142,0,135" HorizontalAlignment="Left"/>
                    <Button Grid.Row="3" Height="23" Width="50" Content="Delete" x:Name="DeletButton" BorderBrush="RosyBrown" Background="white" Click="DeleteButton_Click" Margin="140,139,58,133"/>

                    <!--Meals-->
                    <Label Content="Meal Name" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,170,0,0" Grid.RowSpan="2"/>
                    <TextBox BorderBrush="RosyBrown" Name="Meal_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" Margin="0,170,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                    <Label Content="Time" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,200,0,0" Grid.RowSpan="2"/>
                    <ComboBox x:Name="MealTimeC_ComboBox" Grid.Row="3" Height="23" Width="150" Margin="0,200,0,72" HorizontalAlignment="Right"/>

                    <Label Content="Days" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,235,0,0"/>
                    <CheckBox Content="Mon" x:Name="Monday_CheckBox" HorizontalAlignment="Left" Margin="55,235,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Tue" x:Name="Tuesday_CheckBox" HorizontalAlignment="Left" Margin="105,235,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Wed" x:Name="Wednesday_CheckBox" HorizontalAlignment="Left" Margin="155,235,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Thu" x:Name="Thursday_CheckBox" HorizontalAlignment="Left" Margin="205,235,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Fri" x:Name="Friday_CheckBox" HorizontalAlignment="Left" Margin="75,255,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Sat" x:Name="Saturday_CheckBox" HorizontalAlignment="Left" Margin="125,255,0,0" Grid.Row="3" VerticalAlignment="Top"/>
                    <CheckBox Content="Sun" x:Name="Sunday_CheckBox" HorizontalAlignment="Left" Margin="175,255,0,0" Grid.Row="3" VerticalAlignment="Top"/>

                    <Label Content="Link" Grid.Row="3" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="0,275,0,0" Grid.RowSpan="2"/>
                    <TextBox BorderBrush="RosyBrown" Name="Link_TexBox" Grid.Row="3" HorizontalAlignment="Right" Height="23" Margin="0,275,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="150" Grid.RowSpan="2"/>

                </Grid>
            </Border>

            <!--This is for the left-side columns for the grid-->
            <Grid Grid.Column="0">

                <!--This is for the week day columns-->
                <Grid.RowDefinitions >
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="96"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--This is for meal row-->
                <!--Sunday-->
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Sunday" FontSize="14"  Margin="5" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="-90"/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="SundayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="SundayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="SundayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--Monday-->
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Monday" FontSize="14" Margin="5" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="-90"/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="MondayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="MondayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="MondayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>

                        </Grid>
                    </Grid>
                </Border>

                <!--Tuesday-->
                <Border Grid.Row="2" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Tuesday" FontSize="14" Margin="5" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-90"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="TuesdayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="TuesdayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="TuesdayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--WednesDay-->
                <Border Grid.Row="3" Grid.Column="1" BorderBrush="RosyBrown"  BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Wednesday" FontSize="14" Margin="5" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="-90"/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="WednesdayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="WednesdayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="WednesdayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--Thursday-->
                <Border Grid.Row="4" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Thursday" FontSize="14" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-90"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="ThursdayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="ThursdayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="ThursdayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--Friday-->
                <Border Grid.Row="5" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Friday" FontSize="14" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="5,5,5,5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-90"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="FridayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="FridayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="FridayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--Saturday-->
                <Border Grid.Row="6" Grid.Column="1" BorderBrush="RosyBrown" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Saturday" FontSize="14" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Margin="5">
                            <Label.LayoutTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-90"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Label.LayoutTransform>
                        </Label>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="SaturdayBreakfast" Height="23" Grid.Row="0" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="SaturdayLunch" Height="23" Grid.Row="1" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                            <ListBox x:Name="SaturdayDinner" Height="23" Grid.Row="2" FontSize="13" VerticalAlignment="Center" BorderBrush="Transparent" SelectionChanged="Meal_SelectionChanged"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
